<?xml version="1.0" encoding="utf-8"?>
<!-- Layout para item de nota en RecyclerView del bloc de notas -->
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="4dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground"
    app:cardCornerRadius="8dp"
    app:cardElevation="2dp">

    <!-- Layout horizontal: contenido a la izquierda, botón borrar a la derecha -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="12dp">

        <!-- Contenedor vertical para texto de la nota -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <!-- Título de la nota -->
            <TextView
                android:id="@+id/tituloNota"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Análisis partida vs Carlos"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@android:color/black"/>

            <!-- Fecha de creación de la nota -->
            <TextView
                android:id="@+id/fechaNota"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Hoy, 15:30"
                android:textSize="12sp"
                android:textColor="#666"
                android:layout_marginTop="2dp" />

            <!-- Vista previa del contenido (recortada) -->
            <TextView
                android:id="@+id/previewNota"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="1.e4 e5..."
                android:textSize="14sp"
                android:maxLines="2"
                android:ellipsize="end"
                android:layout_marginTop="4dp" />
        </LinearLayout>

        <!-- Botón para eliminar la nota -->
        <ImageButton
            android:id="@+id/btnBorrar"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@android:drawable/ic_menu_delete"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Borrar nota"
            app:tint="#F44336" />

    </LinearLayout>

</androidx.cardview.widget.CardView>