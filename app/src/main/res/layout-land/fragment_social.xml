<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"> <LinearLayout
    android:layout_width="0dp"
    android:layout_height="match_parent"
    android:layout_weight="0.35"
    android:orientation="vertical"
    android:background="?attr/colorPrimary"> <TextView
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:text="@string/titulo_comunidad"
    android:textColor="@android:color/white"
    android:textSize="20sp"
    android:textStyle="bold"
    android:padding="16dp"
    android:gravity="center"/>

    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tabLayoutSocial"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:tabMode="fixed"
        app:tabGravity="fill"
        android:background="?attr/colorPrimary"
        app:tabTextColor="@android:color/white"
        app:tabSelectedTextColor="#FFD700"> <com.google.android.material.tabs.TabItem
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/tab_feed" />

        <com.google.android.material.tabs.TabItem
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/tab_amigos" />

        <com.google.android.material.tabs.TabItem
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/tab_mensajes" />

    </com.google.android.material.tabs.TabLayout>

    <ImageView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:src="@android:drawable/ic_menu_share"
        android:padding="40dp"
        app:tint="#80FFFFFF"/> </LinearLayout>

    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/viewPagerSocial"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="0.65" />

</LinearLayout>