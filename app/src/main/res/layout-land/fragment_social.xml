<?xml version="1.0" encoding="utf-8"?>
<!-- Layout horizontal del fragmento social -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal">

    <!-- Panel izquierdo: Navegación (35% del ancho) -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="0.35"
        android:orientation="vertical"
        android:background="?attr/colorPrimary">

        <!-- Título de la comunidad -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/titulo_comunidad"
            android:textColor="@android:color/white"
            android:textSize="20sp"
            android:textStyle="bold"
            android:padding="16dp"
            android:gravity="center"/>

        <!-- Tabs de navegación con diseño vertical -->
        <com.google.android.material.tabs.TabLayout
            android:id="@+id/tabLayoutSocial"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:tabMode="fixed"
            app:tabGravity="fill"
            android:background="?attr/colorPrimary"
            app:tabTextColor="@android:color/white"
            app:tabSelectedTextColor="#FFD700">

            <!-- Tab para feed de actividad -->
            <com.google.android.material.tabs.TabItem
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/tab_feed" />

            <!-- Tab para gestión de amigos -->
            <com.google.android.material.tabs.TabItem
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/tab_amigos" />

            <!-- Tab para mensajes privados -->
            <com.google.android.material.tabs.TabItem
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/tab_mensajes" />

        </com.google.android.material.tabs.TabLayout>

        <!-- Icono decorativo -->
        <ImageView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:src="@android:drawable/ic_menu_share"
            android:padding="40dp"
            app:tint="#80FFFFFF"/>

    </LinearLayout>

    <!-- Panel derecho: Contenido (65% del ancho) -->
    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/viewPagerSocial"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="0.65" />

</LinearLayout>