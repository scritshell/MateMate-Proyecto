<?xml version="1.0" encoding="utf-8"?>
<!-- Layout horizontal para el tablero de ajedrez -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:padding="8dp"
    android:baselineAligned="false"
    tools:context=".fragments.ChessBoardFragment">

    <!-- Panel izquierdo: Tablero de ajedrez (60% del ancho) -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1.5">

        <!-- GridView de 8x8 para el tablero -->
        <GridView
            android:id="@+id/chessBoard"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:numColumns="8"
            android:stretchMode="columnWidth"
            android:background="@android:color/transparent"
            app:layout_constraintDimensionRatio="1:1"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Panel derecho: Controles y herramientas (40% del ancho) -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingStart="12dp">

        <!-- Título del tablero -->
        <TextView
            android:id="@+id/titleTextView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/titulo_tablero"
            android:textSize="18sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="4dp" />

        <!-- Card para historial de movimientos -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginBottom="8dp"
            app:cardCornerRadius="8dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:padding="8dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/titulo_historial"
                    android:textStyle="bold"
                    android:textSize="12sp"
                    android:gravity="center"/>

                <!-- RecyclerView para mostrar movimientos -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recyclerHistory"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scrollbars="vertical" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Sección de configuración de IA -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#10000000"
            android:padding="8dp"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tiempo IA:"
                android:textStyle="bold"
                android:textSize="12sp"/>

            <!-- Spinner para seleccionar tiempo de la IA -->
            <Spinner
                android:id="@+id/spinnerTime"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:minHeight="40dp" />

            <!-- Etiqueta del nivel de dificultad -->
            <TextView
                android:id="@+id/tvDifficultyLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nivel IA: 1"
                android:textStyle="bold"
                android:textSize="12sp"/>

            <!-- SeekBar para ajustar dificultad -->
            <SeekBar
                android:id="@+id/seekBarDifficulty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="10"
                android:progress="1"
                android:thumbTint="#673AB7"
                android:progressTint="#673AB7"/>
        </LinearLayout>

        <!-- Sección de botones de control -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Fila de botones: Atrás y Reiniciar -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="4dp">

                <Button
                    android:id="@+id/btnUndo"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/btn_atras"
                    android:textSize="12sp"
                    android:layout_marginEnd="4dp"
                    android:backgroundTint="#9E9E9E"/>

                <Button
                    android:id="@+id/btnReset"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/btn_reiniciar"
                    android:textSize="12sp"
                    android:backgroundTint="#F44336"/>
            </LinearLayout>

            <!-- Botón para guardar partida -->
            <Button android:id="@+id/btnSave"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:backgroundTint="#673AB7"
                android:text="@string/btn_guardar" />
        </LinearLayout>

    </LinearLayout>
</LinearLayout>